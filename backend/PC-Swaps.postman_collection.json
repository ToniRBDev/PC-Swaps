{
  "info": {
    "name": "PC-Swaps API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",        "value": "http://localhost:8080" },
    { "key": "token_vendedor",  "value": "" },
    { "key": "token_comprador", "value": "" },
    { "key": "id_vendedor",     "value": "" },
    { "key": "id_comprador",    "value": "" },
    { "key": "id_articulo",     "value": "" },
    { "key": "id_conversacion", "value": "" }
  ],
  "item": [

    {
      "name": "01 - Auth",
      "item": [

        {
          "name": "Registrar vendedor",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const res = pm.response.json();",
            "pm.test('Devuelve idUsuario', () => pm.expect(res.idUsuario).to.be.a('number'));",
            "pm.collectionVariables.set('id_vendedor', res.idUsuario);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/usuarios/registro",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Carlos\",\n  \"apellidos\": \"García López\",\n  \"dni\": \"11111111A\",\n  \"correoElectronico\": \"vendedor@pcswaps.com\",\n  \"fechaNacimiento\": \"1990-05-15\",\n  \"direccion\": \"Calle Mayor 10, Madrid\",\n  \"numTelefono\": \"600111222\",\n  \"nombreUsuario\": \"carlosgamer\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "Login vendedor",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Devuelve token', () => pm.expect(res.token).to.be.a('string'));",
            "pm.collectionVariables.set('token_vendedor', res.token);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correoElectronico\": \"vendedor@pcswaps.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "Registrar comprador",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const res = pm.response.json();",
            "pm.test('Devuelve idUsuario', () => pm.expect(res.idUsuario).to.be.a('number'));",
            "pm.collectionVariables.set('id_comprador', res.idUsuario);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/usuarios/registro",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana\",\n  \"apellidos\": \"Martínez Ruiz\",\n  \"dni\": \"22222222B\",\n  \"correoElectronico\": \"comprador@pcswaps.com\",\n  \"fechaNacimiento\": \"1995-11-20\",\n  \"direccion\": \"Avenida del Sol 5, Barcelona\",\n  \"numTelefono\": \"611333444\",\n  \"nombreUsuario\": \"anamartinez\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "Login comprador",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Devuelve token', () => pm.expect(res.token).to.be.a('string'));",
            "pm.collectionVariables.set('token_comprador', res.token);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correoElectronico\": \"comprador@pcswaps.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "Login incorrecto (credenciales erróneas)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correoElectronico\": \"vendedor@pcswaps.com\",\n  \"password\": \"contraseñaIncorrecta\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "02 - Categorias",
      "item": [

        {
          "name": "Listar categorías",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Devuelve 5 categorías', () => pm.expect(res).to.have.lengthOf(5));",
            "pm.test('Contiene Procesadores', () => {",
            "  const nombres = res.map(c => c.nombreCategoria);",
            "  pm.expect(nombres).to.include('Procesadores');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/categorias",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_vendedor}}" }]
          }
        }

      ]
    },

    {
      "name": "03 - Usuarios",
      "item": [

        {
          "name": "Ver mi perfil (vendedor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Correo correcto', () => pm.expect(res.correoElectronico).to.eql('vendedor@pcswaps.com'));",
            "pm.test('Nombre de usuario correcto', () => pm.expect(res.nombreUsuario).to.eql('carlosgamer'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/usuarios/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_vendedor}}" }]
          }
        },

        {
          "name": "Ver datos de contacto del vendedor",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Tiene correo', () => pm.expect(res.correoElectronico).to.be.a('string'));",
            "pm.test('Tiene teléfono', () => pm.expect(res.numTelefono).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/usuarios/{{id_vendedor}}/contacto",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        },

        {
          "name": "Actualizar perfil (vendedor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Dirección actualizada', () => pm.expect(res.direccion).to.eql('Calle Nueva 99, Madrid'));"
          ]}}],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/usuarios/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_vendedor}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreUsuario\": \"carlosgamer\",\n  \"direccion\": \"Calle Nueva 99, Madrid\",\n  \"numTelefono\": \"699888777\"\n}"
            }
          }
        },

        {
          "name": "Cambiar contraseña (vendedor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/usuarios/me/password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_vendedor}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passwordActual\": \"Password123\",\n  \"passwordNueva\": \"NuevaPassword456\"\n}"
            }
          }
        },

        {
          "name": "Login vendedor (nueva contraseña)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.collectionVariables.set('token_vendedor', res.token);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correoElectronico\": \"vendedor@pcswaps.com\",\n  \"password\": \"NuevaPassword456\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "04 - Articulos",
      "item": [

        {
          "name": "Publicar artículo (vendedor) ⚠️ seleccionar imagen",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const res = pm.response.json();",
            "pm.test('Tiene idArticulo', () => pm.expect(res.idArticulo).to.be.a('number'));",
            "pm.test('Marca correcta', () => pm.expect(res.marca).to.eql('AMD'));",
            "pm.collectionVariables.set('id_articulo', res.idArticulo);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/articulos",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_vendedor}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "articulo",
                  "value": "{\"idCategoria\":3,\"marca\":\"AMD\",\"modelo\":\"Ryzen 7 5800X\",\"estado\":\"COMO_NUEVO\",\"precio\":150.00,\"descripcion\":\"Procesador AMD Ryzen 7 5800X en perfecto estado. Apenas usado, viene con caja original.\"}",
                  "contentType": "application/json",
                  "type": "text"
                },
                {
                  "key": "imagen",
                  "type": "file",
                  "src": []
                }
              ]
            }
          }
        },

        {
          "name": "Publicar segundo artículo (vendedor) ⚠️ seleccionar imagen",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const res = pm.response.json();",
            "pm.test('Tiene idArticulo', () => pm.expect(res.idArticulo).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/articulos",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_vendedor}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "articulo",
                  "value": "{\"idCategoria\":1,\"marca\":\"NVIDIA\",\"modelo\":\"RTX 4070\",\"estado\":\"BUENO\",\"precio\":450.00,\"descripcion\":\"Tarjeta gráfica NVIDIA RTX 4070 en buen estado. Sin defectos visuales, funciona perfectamente.\"}",
                  "contentType": "application/json",
                  "type": "text"
                },
                {
                  "key": "imagen",
                  "type": "file",
                  "src": []
                }
              ]
            }
          }
        },

        {
          "name": "Listar todos (comprador - ve artículos del vendedor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Es un array', () => pm.expect(res).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/articulos",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        },

        {
          "name": "Ver detalle del artículo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Tiene marca', () => pm.expect(res.marca).to.be.a('string'));",
            "pm.test('Tiene precio', () => pm.expect(res.precio).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/articulos/{{id_articulo}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        },

        {
          "name": "Listar propios (vendedor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Es un array', () => pm.expect(res).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/articulos/propios",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_vendedor}}" }]
          }
        },

        {
          "name": "Buscar por texto",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Es un array', () => pm.expect(res).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/articulos/buscar?texto=ryzen",
              "query": [{ "key": "texto", "value": "ryzen" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        },

        {
          "name": "Listar por categoría (Procesadores - id 3)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Es un array', () => pm.expect(res).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/articulos/categoria/3",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        },

        {
          "name": "Editar artículo (vendedor) ⚠️ imagen opcional",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Precio actualizado', () => pm.expect(res.precio).to.eql(130));"
          ]}}],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/articulos/{{id_articulo}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_vendedor}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "articulo",
                  "value": "{\"idCategoria\":3,\"marca\":\"AMD\",\"modelo\":\"Ryzen 7 5800X\",\"estado\":\"COMO_NUEVO\",\"precio\":130.00,\"descripcion\":\"Precio rebajado. Procesador AMD Ryzen 7 5800X en perfecto estado.\"}",
                  "contentType": "application/json",
                  "type": "text"
                }
              ]
            }
          }
        },

        {
          "name": "Renovar artículo (vendedor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/articulos/{{id_articulo}}/renovar",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_vendedor}}" }]
          }
        },

        {
          "name": "Editar artículo ajeno (comprador) → 403",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 403', () => pm.response.to.have.status(403));"
          ]}}],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/articulos/{{id_articulo}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "articulo",
                  "value": "{\"idCategoria\":3,\"marca\":\"AMD\",\"modelo\":\"Ryzen 7 5800X\",\"estado\":\"BUENO\",\"precio\":50.00,\"descripcion\":\"Intento de edición no autorizada.\"}",
                  "contentType": "application/json",
                  "type": "text"
                }
              ]
            }
          }
        }

      ]
    },

    {
      "name": "05 - Seguimientos",
      "item": [

        {
          "name": "Agregar artículo a seguimiento (comprador)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/seguimientos/{{id_articulo}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        },

        {
          "name": "Listar seguimientos (comprador)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Es un array con al menos 1 elemento', () => pm.expect(res.length).to.be.at.least(1));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/seguimientos",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        },

        {
          "name": "Eliminar seguimiento (comprador)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/seguimientos/{{id_articulo}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        }

      ]
    },

    {
      "name": "06 - Conversaciones",
      "item": [

        {
          "name": "Iniciar conversación (comprador sobre artículo del vendedor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const res = pm.response.json();",
            "pm.test('Tiene idConversacion', () => pm.expect(res.idConversacion).to.be.a('number'));",
            "pm.collectionVariables.set('id_conversacion', res.idConversacion);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/conversaciones",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_comprador}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idArticulo\": {{id_articulo}}\n}"
            }
          }
        },

        {
          "name": "Listar conversaciones (comprador)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Es un array con al menos 1 elemento', () => pm.expect(res.length).to.be.at.least(1));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/conversaciones",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        },

        {
          "name": "Ver conversación (comprador)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "pm.test('Tiene mensajes', () => pm.expect(res.mensajes).to.be.an('array'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/conversaciones/{{id_conversacion}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_comprador}}" }]
          }
        }

      ]
    },

    {
      "name": "07 - Mensajes",
      "item": [

        {
          "name": "Enviar mensaje (comprador)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const res = pm.response.json();",
            "pm.test('Tiene idMensaje', () => pm.expect(res.idMensaje).to.be.a('number'));",
            "pm.test('No está leído', () => pm.expect(res.leido).to.be.false);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/mensajes",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_comprador}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idConversacion\": {{id_conversacion}},\n  \"contenido\": \"Hola, ¿sigue disponible el procesador? ¿Tienes fotos adicionales?\"\n}"
            }
          }
        },

        {
          "name": "Responder mensaje (vendedor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const res = pm.response.json();",
            "pm.test('Tiene contenido', () => pm.expect(res.contenido).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/mensajes",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_vendedor}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idConversacion\": {{id_conversacion}},\n  \"contenido\": \"¡Hola! Sí, sigue disponible. Te mando más fotos en breve.\"\n}"
            }
          }
        },

        {
          "name": "Marcar mensajes como leídos (comprador)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],

# ============================================================
# VARIABLES DE ENTORNO — DESARROLLO LOCAL
# Copia este archivo como .env y rellena los valores reales.
# Nunca subas el .env al repositorio.
# ============================================================

# Base de datos (usadas por Docker Compose en local)
MYSQL_DATABASE=pc-swaps
MYSQL_USER=tonidam
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me

# JWT
JWT_SECRET=change_me_min_32_bytes_en_base64


# ============================================================
# VARIABLES DE ENTORNO — PRODUCCIÓN (Railway)
# Estas variables las configuras manualmente en el dashboard de Railway.
# Las de la BD (MYSQL*) las genera Railway automáticamente al añadir
# el plugin de MySQL; el resto las introduces tú.
# ============================================================

# Base de datos — proporcionadas automáticamente por el plugin MySQL de Railway
# MYSQLHOST=
# MYSQLPORT=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=

# JWT — la introduces tú en el dashboard de Railway
# JWT_SECRET=change_me_min_32_bytes_en_base64

# Duración del token en ms (opcional, por defecto 86400000 = 24h)
# JWT_EXPIRATION=86400000

# Origen del frontend (la URL que te da Vercel/Netlify al desplegar)
# CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app

# Perfil de Spring Boot
# SPRING_PROFILES_ACTIVE=prod
